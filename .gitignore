# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# MCP server dists are load-bearing for `claude plugin install` —
# end users get the built JS without having to run a build step.
# The negation keeps the dist/ rule but un-ignores the five
# mcp-servers/*/dist directories specifically. Source maps stay
# ignored to keep the tarball lean.
!mcp-servers/*/dist/
!mcp-servers/*/dist/**
mcp-servers/*/dist/**/*.map

# Test coverage
coverage/
.nyc_output/

# Runtime state (per-project, not source)
.vibeflow/state.db
.vibeflow/state.db-shm
.vibeflow/state.db-wal
.vibeflow/artifacts/
.vibeflow/reports/
.vibeflow/traces/
.vibeflow/state/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local environment
.env
.env.local

# Claude local settings (per-user, not source)
.claude/settings.local.json

# Plugin packaging output — package-plugin.sh writes here, but the
# archive itself is build output and not source.
vibeflow-plugin-*.tar.gz
vibeflow-plugin-*.tar.gz.sha256
