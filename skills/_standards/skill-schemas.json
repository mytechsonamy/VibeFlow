{
  "_meta": {
    "version": "1.0",
    "description": "TruthLayer Platform — 26 skill için machine-readable input/output contract",
    "fileNamingConvention": "Dosya adları sabittir. Konum (klasör) esnektir.",
    "inputTypes": {
      "PRD": "Ürün gereksinim dokümanı — metin veya dosya yolu",
