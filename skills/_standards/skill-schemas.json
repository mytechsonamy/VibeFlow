      "TEST_FILES": "Test dosyaları veya klasör yolu",
      "SCENARIO_SET": "scenario-set.md — test-strategy-planner çıktısı",
      "BASELINE": "regression-baseline.json — önceki koşum sonucu",
      "SCREENSHOT": "PNG veya JPG dosya yolu / URL",
      "OPENAPI": "OpenAPI/Swagger YAML veya JSON dosyası / URL",
      "CONFIG": "Parametre veya konfigürasyon — inline değer"
    }
  },
